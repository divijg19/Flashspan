{
	"name": "flashspan",
	"private": true,
	"version": "2.3.1",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"lint": "biome check . --write",
		"format": "biome format . --write",
		"build:wasm": "wasm-pack build ./src-tauri --target web --out-dir ../src/wasm/pkg --out-name flashspan_core",
		"build:web": "bun run build:wasm && bun run build",
		"preview": "vite preview",
		"test": "vitest --run"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.11.0",
		"solid-js": "^1.9.13"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@solidjs/testing-library": "^0.8.10",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/user-event": "^14.6.1",
		"@vitest/coverage-v8": "4.1.8",
		"jsdom": "^29.1.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vite-plugin-solid": "^2.11.12",
		"vitest": "^4.1.8"
	}
}
